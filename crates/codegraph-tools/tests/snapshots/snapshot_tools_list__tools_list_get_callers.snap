{
  "name": "get_callers",
  "description": "Find functions that call the given symbol (upstream call chain)",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "depth": {
        "default": null,
        "description": "Maximum traversal depth (default 1)",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "symbol": {
        "description": "Symbol ID in format file:name",
        "type": "string"
      }
    },
    "required": [
      "symbol"
    ],
    "title": "GetCallersArgs",
    "type": "object"
  }
}
