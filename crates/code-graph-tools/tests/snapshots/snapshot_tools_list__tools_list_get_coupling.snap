expression: "tool_entry(\"get_coupling\")"
---
{
  "name": "get_coupling",
  "description": "Get cross-file dependency counts for a file. Path is resolved against the indexed graph; `\\\\?\\` extended-path prefix is handled automatically, and relative segments (`.` / `..`) resolve against the on-disk file when it exists (otherwise lexical-only).",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "direction": {
        "default": null,
        "description": "'outgoing' (default), 'incoming', or 'both'",
        "type": [
          "string",
          "null"
        ]
      },
      "file": {
        "description": "Absolute path to the source file",
        "type": "string"
      },
      "limit": {
        "default": null,
        "description": "Maximum results to return per side (default 50, max 1000)",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "offset": {
        "default": null,
        "description": "Skip first N matches for pagination (default 0)",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      }
    },
    "required": [
      "file"
    ],
    "title": "GetCouplingArgs",
    "type": "object"
  }
}
