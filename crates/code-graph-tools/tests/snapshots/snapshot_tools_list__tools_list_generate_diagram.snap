---
source: crates/code-graph-tools/tests/snapshot_tools_list.rs
assertion_line: 101
expression: "tool_entry(\"generate_diagram\")"
---
{
  "name": "generate_diagram",
  "description": "Generate a graph diagram: call graph (symbol), file dependencies (file), or inheritance tree (class). Returns edges as JSON by default, or Mermaid syntax when format=mermaid. When `file=` is used, the path is resolved against the indexed graph; `\\\\?\\` extended-path prefix is handled automatically, and relative segments (`.` / `..`) resolve against the on-disk file when it exists (otherwise lexical-only). The `symbol=` and `class=` modes take identifiers, not paths, and are NOT normalized — pass them exactly as they appear in the index.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "class": {
        "default": null,
        "description": "Class name to center the inheritance diagram on",
        "type": [
          "string",
          "null"
        ]
      },
      "depth": {
        "default": null,
        "description": "BFS traversal depth (default 1)",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "direction": {
        "default": null,
        "description": "Call-graph direction (symbol mode only): 'callees', 'callers', or 'both' (default)",
        "type": [
          "string",
          "null"
        ]
      },
      "file": {
        "default": null,
        "description": "File path to center the dependency graph on",
        "type": [
          "string",
          "null"
        ]
      },
      "format": {
        "default": null,
        "description": "Output format: 'edges' (default, minimal JSON) or 'mermaid' (Mermaid flowchart syntax)",
        "type": [
          "string",
          "null"
        ]
      },
      "max_nodes": {
        "default": null,
        "description": "Maximum nodes in diagram (default 30)",
        "format": "uint32",
        "minimum": 0,
        "type": [
          "integer",
          "null"
        ]
      },
      "styled": {
        "default": null,
        "description": "When format=mermaid, add CSS styling and center node highlighting (default false)",
        "type": [
          "boolean",
          "null"
        ]
      },
      "symbol": {
        "default": null,
        "description": "Symbol ID to center the call graph on (format: file:name)",
        "type": [
          "string",
          "null"
        ]
      }
    },
    "title": "GenerateDiagramArgs",
    "type": "object"
  }
}
