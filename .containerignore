# the context lean so the image build doesn't drag in build outputs, the local
# cargo/registry cache, the on-disk graph cache, VCS metadata, or the large
# external/ dogfood corpora (test fixtures, not build inputs).
target/
.cache/
.git/
.idea/
.code-graph-cache.db
.code-graph-cache.json
.code-graph.toml
external/
dist/
