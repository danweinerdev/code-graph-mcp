# Optional configuration for code-graph-mcp.
#
# Place this file at the root of the project you want to index, named exactly
# `.code-graph.toml` (without the `.example` suffix). Missing file ÔåÆ defaults
# below are used. Malformed TOML ÔåÆ analyze_codebase fails with a parse error
# (no silent fallback).
#
# All keys are optional; defaults are shown.

[discovery]
# Number of threads for the parallel filesystem walker (`ignore::WalkBuilder`).
# 0 = auto (`std::thread::available_parallelism`). Values exceeding the host's
# logical CPU count are clamped at load time, and a warning is surfaced via
# `analyze_codebase`'s `warnings` array.
max_threads = 0

# If true, the walker honors `.gitignore`, `.ignore`, and global ignore files
# (matches `ignore::WalkBuilder` defaults). Default: true.
respect_gitignore = true

# If true, the walker follows symlinks. Default: false (avoids cycles).
follow_symlinks = false

# Additional gitignore-style globs to exclude from discovery, layered on top
# of the gitignore handling above. Patterns follow the `ignore` crate's
# gitignore syntax.
extra_ignore = ["build/", "node_modules/", "vendor/"]

# Recommended starting point for Unreal Engine codebases (opt-in: replace
# the `extra_ignore` line above with this one, or merge the entries you
# want). Left commented so the default behavior is unchanged ÔÇö a user who
# copies this example as-is gets no UE-specific exclusions until they opt
# in. Every directory below is engine-side scratch that regenerates on
# every build and carries zero source signal: `Intermediate/` (build
# intermediates), `Saved/` (autosaves, logs, crash dumps), `Binaries/`
# (compiled module DLLs/PDBs), `DerivedDataCache/` (the DDC blob store).
# `.vs/`, `.idea/`, `.vscode/` are IDE working dirs. `*.uasset` and
# `*.umap` are large packed binary content assets, not parseable source ÔÇö
# excluding them keeps the walker off multi-gigabyte content trees.
# Indexing any of these wastes discovery time and pollutes the graph with
# regenerated noise.
# extra_ignore = ["Intermediate/", "Saved/", "Binaries/", "DerivedDataCache/", ".vs/", ".idea/", ".vscode/", "*.uasset", "*.umap"]

[parsing]
# Number of threads for the rayon parsing pool. 0 = auto. Same clamping rule
# as `discovery.max_threads`. The discovery and parsing pools share the host
# concurrency budget ÔÇö the indexer caps the sum at the host's logical CPU
# count.
max_threads = 0

[response]
# Byte cap on paginated MCP responses. When a page would exceed this
# size, the server truncates mid-page and surfaces `truncated: true`
# plus a `next_offset` to resume paging. Default chosen to fit Claude
# Code's harness; raise for clients with larger token budgets.
# max_bytes = 102400

# C++-specific knobs. The `macro_strip` list contains identifier tokens to
# whole-word-replace with spaces in C++ source bytes before tree-sitter
# parses. Use this for API-export macros that confuse the tree-sitter-cpp
# grammar by occupying the position between `class` and the class name ÔÇö
# `class CORE_API MyClass : public Base {};` is invisible to the parser
# until `CORE_API` is stripped. Replacement preserves byte length (and
# therefore line/column offsets) so reported symbol positions match the
# original source on disk. Default: omit `[cpp]` entirely (equivalent to
# `macro_strip = []`).
#
# After changing this list, re-run analyze_codebase with force=true to
# invalidate the mtime-based cache. Without `force=true`, files whose
# mtime hasn't changed since the last index will skip preprocessing and
# the new strip list will appear to have no effect.
#
# Suggested list for Unreal Engine codebases (uncomment to opt in, then
# add any project-local <PROJECTNAME>_API macros). Pair `macro_strip`
# (bare-token API macros) with `macro_strip_with_args` (parameterized
# reflection macros ÔÇö see below) to get full UE coverage.
# [cpp]
# macro_strip = [
#   "CORE_API", "ENGINE_API", "UMG_API", "SLATE_API",
#   "RENDERCORE_API", "NIAGARA_API", "ONLINESUBSYSTEM_API",
#   "GAMEPLAYABILITIES_API",
# ]
#
# `macro_strip_with_args` strips identifier-plus-parenthesized-arg-list
# constructs ÔÇö `UCLASS(BlueprintType, ÔÇĞ)`, `UFUNCTION(...)`,
# `UPROPERTY(...)`, `GENERATED_BODY()`, delegate-family macros. Without
# this, tree-sitter-cpp sees the unstripped `UCLASS(...)` on a class
# declaration line and produces an ERROR node that swallows the
# surrounding class ÔÇö every UE class disappears from the index. Same
# byte-length-preserving substitution as `macro_strip`; `\n` bytes are
# preserved during the fill so multi-line macros (e.g.
# `DECLARE_DELEGATE_TwoParams(\n  FOnHit, ÔÇĞ)`) keep line numbers aligned.
#
# Recommended UE preset:
# macro_strip_with_args = [
#   # Reflection / metadata macros
#   "UCLASS", "USTRUCT", "UENUM", "UFUNCTION", "UPROPERTY",
#   "UINTERFACE", "UDELEGATE", "UPARAM", "UMETA",
#   # Generated-body markers
#   "GENERATED_BODY", "GENERATED_UCLASS_BODY", "GENERATED_USTRUCT_BODY",
#   "GENERATED_UINTERFACE_BODY", "GENERATED_IINTERFACE_BODY",
#   # Delegate macro families (UE5; UE4 also uses these)
#   "DECLARE_DYNAMIC_MULTICAST_DELEGATE",
#   "DECLARE_DYNAMIC_MULTICAST_DELEGATE_OneParam",
#   "DECLARE_DYNAMIC_MULTICAST_DELEGATE_TwoParams",
#   "DECLARE_DYNAMIC_MULTICAST_DELEGATE_ThreeParams",
#   "DECLARE_DELEGATE", "DECLARE_DELEGATE_OneParam",
#   "DECLARE_DELEGATE_TwoParams", "DECLARE_DELEGATE_RetVal",
#   "DECLARE_MULTICAST_DELEGATE", "DECLARE_EVENT",
# ]
#
# Project-specific additions you may want manually (uncomment as needed):
#   "DEPRECATED", "UE_DEPRECATED"  # deprecation annotation macros
#
# DO NOT add `WITH_EDITOR`, `WITH_EDITORONLY_DATA`,
# `WITH_DEV_AUTOMATION_TESTS`, or other `#if`-guarded identifiers to
# `macro_strip` ÔÇö they appear inside `#if` expressions and the
# whole-word substitution would blank them, breaking conditional
# compilation silently. They are harmless to omit from
# `macro_strip_with_args` too (they never appear with trailing parens,
# so the parameterized scanner skips them either way; adding them there
# has no effect).
#
# A token may appear in `macro_strip` OR `macro_strip_with_args` but
# NOT both ÔÇö the load fails with `MacroStripConflict` if you list a
# name in both. The two scans are disjoint by definition: bare
# identifiers vs identifier+parens.
#
# After changing this list, re-run analyze_codebase with force=true to
# invalidate the mtime-based cache. Without `force=true`, files whose
# mtime hasn't changed since the last index will skip preprocessing and
# the new strip list will appear to have no effect.
#
# `macro_define_function` recovers FUNCTION definitions that a token-pasting
# macro hides from tree-sitter. For each invocation `MACRO(arg0, ÔÇĞ)` of a
# configured macro it SYNTHESIZES a `Function` symbol named
# `<arg><suffix>` (no byte rewrite). Opt-in; empty by default. Example ÔÇö
# `IMPLEMENT_RELEASE_FN(Bar)` synthesizes the `Bar_Release` function:
# [[cpp.macro_define_function]]
# name = "IMPLEMENT_RELEASE_FN"
# arg = 0          # 0-based index of the arg naming the function (default 0)
# suffix = "_Release"  # appended to the captured arg (default "")
# (Within-list duplicates dedup by `name`. A config change needs force=true,
#  same mtime-stale rule as macro_strip.)
#
# `macro_define_type` recovers a STRUCT/CLASS definition wrapped in a macro
# by EXPANDING the invocation IN PLACE into native C++ (byte-preserving:
# same length, every `\n` at its original offset), so tree-sitter recovers
# the type symbol AND its members AND inheritance/call edges. Runs in the
# preprocess pass BEFORE the strip passes. Opt-in; empty by default.
# Example ÔÇö given `#define EXPORT_STRUCT(name, ...) struct name { __VA_ARGS__ }`
# and `EXPORT_STRUCT(Foo, ( int bar; void method() {} ));`, this recovers the
# `Foo` struct, its `bar` field, and its `method`:
# [[cpp.macro_define_type]]
# name = "EXPORT_STRUCT"
# name_arg = 0     # 0-based index of the arg holding the type name (default 0)
# # body_arg = 1   # 0-based index of the arg holding the member body
# #                # (omit = the LAST arg, the __VA_ARGS__ tail)
# keyword = "struct"  # "struct" (default) or "class"; any other value is a
# #                   # load error (MacroDefineTypeKeyword). Empty `name` is
# #                   # a load error (MacroDefineTypeEmptyName).
# (The keyword must FIT in the macro-name span ÔÇö struct=6 Ôëñ EXPORT_STRUCT=13;
#  if longer, that invocation is skipped with an eprintln! warning. A
#  paren-wrapped body `(ÔÇĞ)` is unwrapped. Within-list dedup by `name`. A
#  config change needs force=true, same mtime-stale rule as macro_strip.)

# Per-language file-extension overrides, layered on top of each plugin's
# built-in extension list. Three semantics:
#
#   1. <lang> lists ADD extensions to that language's claim. A file whose
#      extension matches `[extensions].cpp` dispatches to the C++ plugin
#      even when no plugin's defaults claim it.
#
#   2. A user addition WINS over a default-claim collision. If
#      `[extensions].python = [".h"]`, then `.h` files dispatch to Python
#      even though the C++ plugin's defaults also claim `.h`. (You wrote
#      it deliberately; the dispatch honors it.) Two `[extensions].<lang>`
#      lists claiming the same extension is a hard load-time error ÔÇö there's
#      no principled tiebreak between two user overrides.
#
#   3. `disabled` lists SUPPRESS extensions entirely. A file matching an
#      entry in `disabled` is dropped at discovery regardless of which
#      plugin or override would otherwise claim it. `disabled` wins over
#      both defaults and additions.
#
# Each entry must start with `.` and is lowercased at load time. Empty
# strings are dropped with an `eprintln!` notice. Defaults: omit
# `[extensions]` entirely (every list empty).
#
# Built-in defaults per language:
#   cpp    : .cpp .cc .cxx .c .h .hpp .hxx
#   rust   : .rs
#   go     : .go
#   python : .py .pyi
#   csharp : .cs
#   java   : .java
#
# [extensions]
# # Suppress C headers from a Python-heavy repo with vendored C/C++:
# disabled = [".h"]
# # Treat CUDA + inline files as C++:
# cpp = [".cu", ".inl"]
# # Treat Cython sources as Python:
# python = [".pyx"]
# # Per-language additive lists for the remaining plugins:
# csharp = []
# java   = []
